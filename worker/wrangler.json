{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "loro-svelte-flow-worker",
	"main": "src/worker.ts",
	"compatibility_date": "2025-02-04",
	"triggers": {
		"crons": [
			"0 0 * * *"
		]
	},
	"durable_objects": {
		"bindings": [
			{
				"name": "SOCKET_OBJECT",
				"class_name": "SocketObject"
			}
		]
	},
	"r2_buckets": [
		{
			"binding": "FLOW_BUCKET",
			"bucket_name": "loro-doc"
		}
	],
	"kv_namespaces": [
		{
			"binding": "FLOW_KV",
			"id": "d5f2e6ce70ba440bac099a4e3402720f"
		}
	],
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": [
				"SocketObject"
			]
		}
	],
	"observability": {
		"enabled": true
	},
	"tail_consumers": [
		{
			"service": "loro-svelte-flow-worker-tail"
		}
	]
}
